# Optimizely Graph — runtime content reads (used by @optimizely/cms-sdk GraphClient)
# Find in: Optimizely CMS portal → Settings → API Keys → "Single Key" (read-only public key, safe to ship to the browser)
OPTIMIZELY_GRAPH_SINGLE_KEY=
# Optional. Defaults to https://cg.optimizely.com/content/v2 when omitted.
# Override only if your instance uses a regional gateway.
OPTIMIZELY_GRAPH_GATEWAY=

# Optimizely CMS — used by @optimizely/cms-cli `config push` (code-first content type sync)
# Find in: Optimizely CMS portal → Settings → API Clients
OPTIMIZELY_CMS_URL=
OPTIMIZELY_CMS_CLIENT_ID=
OPTIMIZELY_CMS_CLIENT_SECRET=

# Optimizely Web Experimentation — client-side A/B snippet
# Find in: Optimizely Web app → Settings → Project (Snippet ID at top)
NEXT_PUBLIC_OPTIMIZELY_WEB_SNIPPET_ID=

# Optimizely Feature Experimentation — server-side flags & experiments
# Find in: Optimizely Feature Experimentation app → Settings → Environments → SDK Key
OPTIMIZELY_FX_SDK_KEY=
